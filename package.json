{
  "name": "z0-auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "start": "NODE_ENV=production bun dist/server.js",
    "build": "bun src/scripts/build.ts",
    "test": "bun test --preload ./tests/preload.ts --max-concurrency=1 --parallel=1 tests/unit tests/integration tests/api",
    "quality:alpha": "NODE_ENV=test bun src/scripts/alpha-quality-gate.ts",
    "test:docker": "sh docker/smoke-test.sh",
    "db:test:init": "NODE_ENV=test bun src/scripts/db-ensure-test.ts",
    "test:e2e": "NODE_ENV=test bun --env-file=.env.test playwright test",
    "test:e2e:ui": "NODE_ENV=test bun --env-file=.env.test playwright test --ui",
    "generate-keys": "bun src/scripts/generate-keys.ts",
    "mfa:reset-owner": "bun src/scripts/reset-owner-mfa.ts",
    "db:reset": "bun src/scripts/db-reset.ts",
    "db:migrate": "bun src/scripts/db-migrate.ts"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@simplewebauthn/server": "^13.3.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "htmx.org": "^2.0.8",
    "lucide-react": "^1.17.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.1.16"
  }
}
