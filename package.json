{
  "name": "z0-auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "start": "NODE_ENV=production bun src/server.ts",
    "build": "bun src/scripts/build.ts",
    "test": "bun test --preload ./tests/preload.ts --concurrency=1 tests/unit tests/integration tests/api",
    "db:test:init": "bun src/scripts/db-ensure-test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:reset": "bun src/scripts/db-reset.ts",
    "db:setup": "bun src/scripts/db-reset.ts"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "htmx.org": "^2.0.8",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "bun-plugin-tailwind": "^0.1.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tailwindcss": "^4.1.16"
  }
}
