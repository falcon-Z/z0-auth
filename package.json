{
  "name": "z0-auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "css:build": "bunx @tailwindcss/cli -i src/app/console/styles/globals.css -o src/app/console/styles/bundle.css",
    "css:watch": "bunx @tailwindcss/cli -i src/app/console/styles/globals.css -o src/app/console/styles/bundle.css --watch",
    "predev": "bun run css:build",
    "prebuild": "bun run css:build",
    "dev": "bun run css:watch & bun --hot src/server.ts",
    "start": "NODE_ENV=production bun src/server.ts",
    "build": "bun build --target=bun --production --outdir=dist ./src/server.ts",
    "test": "bun test --concurrency=1",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:reset": "bun src/scripts/db-reset.ts",
    "db:setup": "bun src/scripts/db-reset.ts"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "htmx.org": "^2.0.8",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.3.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "tailwindcss": "^4.1.16"
  }
}
