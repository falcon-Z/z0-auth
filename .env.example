# ─────────────────────────────────────────────────────────────────────────────
# Z0 Auth – Environment Variables
# Copy this file to .env and fill in the values before running the app.
# Never commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME="Z0 Auth"
APP_URL=http://localhost:3000

# Secret used for symmetric encryption (sessions, tokens, etc.)
# Generate a strong random value: openssl rand -hex 32
APP_SECRET=change-me-use-openssl-rand-hex-32

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Replace DB_USER and DB_PASSWORD with your actual credentials.
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@localhost:5432/z0auth

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (production only)
ALLOWED_ORIGINS=https://yourdomain.com

# ── SMTP / Email ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME="Z0 Auth"
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Key used to encrypt SMTP credentials at rest
# Generate: openssl rand -hex 32
SMTP_ENCRYPTION_KEY=change-me-use-openssl-rand-hex-32

# ── Misc ─────────────────────────────────────────────────────────────────────
# Optional: request timeout in milliseconds (default: 30000)
# REQUEST_TIMEOUT=30000

# Optional: primary colour used in email templates (hex, no #)
# EMAIL_PRIMARY_COLOR=6366f1
