# Same variable names in every environment — only values change.
#
#   Dev:        copy to `.env` (Bun loads automatically for `bun dev`, db scripts)
#   Test:       copy to `.env.test` (Bun loads when NODE_ENV=test; overrides `.env`)
#   CI / deploy: set these variables in GitHub Actions / your platform — no .env files
#
# Test uses a separate Postgres database on the same instance. One-time: bun run db:test:init

# PostgreSQL (Bun SQL reads DATABASE_URL)
# Dev:  z0auth       Test: z0auth_test
DATABASE_URL=postgresql://postgres:password@localhost:5432/z0auth

# Server — set PORT only for local dev (binds to 127.0.0.1 automatically)
PORT=3000
APP_NAME=z0-auth
# Public origin for OAuth/OIDC issuer in production (e.g. https://auth.example.com)
# PUBLIC_ORIGIN=https://auth.example.com
NODE_ENV=development
# BIND_ADDRESS=127.0.0.1

# Optional: require this token on POST /api/setup (recommended in production)
# INSTALL_TOKEN=change-me-before-first-run

# Optional: create the first owner from deployment configuration.
# If any Z0_BOOTSTRAP_* value is set, all four are required for automatic setup.
# Z0_BOOTSTRAP_ORG_NAME=Acme IAM
# Z0_BOOTSTRAP_ADMIN_NAME=Owner User
# Z0_BOOTSTRAP_ADMIN_EMAIL=owner@example.com
# Z0_BOOTSTRAP_ADMIN_PASSWORD=use-a-strong-unique-password

# Allow API use before platform setup completes (maintenance only — bypasses setup guard)
# ALLOW_INCOMPLETE_SETUP=true

# Stable AES-256 key for encrypting SMTP password etc. REQUIRED in production / Kubernetes.
# Generate once: bun run generate-keys
# Same ID and value on every pod. Rotation requires a planned key-ring workflow.
# Test: use a fixed test-only value in `.env.test` (see docs/development.md)
# INSTANCE_DATA_KEY_ID=data-2026-07
# INSTANCE_DATA_KEY=<64-char-hex-or-base64-32-bytes>

# Ed25519 keys for password-reset link signatures (required in production; same on every pod).
# INSTANCE_TOKEN_KEY_ID=token-2026-07
# INSTANCE_TOKEN_PRIVATE_KEY=
# INSTANCE_TOKEN_PUBLIC_KEY=

# Dev/test fallback: auto-generated keys file when instance key env vars are unset.
# Production does not auto-generate root keys.
# Test: .data/test-instance-keys.json
# INSTANCE_KEYS_PATH=.data/instance-keys.json

# Integration tests: capture outbound email instead of connecting to SMTP
# Z0_SMTP_CAPTURE=1

# Optional SMTP from environment (wins over console settings when set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_ENCRYPTION=starttls
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=noreply@example.com
# SMTP_FROM_NAME=z0-auth
# SMTP_ENABLED=true
